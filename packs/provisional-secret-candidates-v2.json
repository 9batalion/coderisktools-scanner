{
  "schema": "coderisktools.rule-source-pack",
  "version": 2,
  "pack_id": "provisional-secret-candidates",
  "tier": "provisional",
  "rules": [
    {
      "rule_id": "CRT-PROV-001",
      "name": "OPENROUTER_API_KEY_CANDIDATE",
      "regex": "sk-or-v1-[A-Za-z0-9_-]{20,200}(?![A-Za-z0-9_-])",
      "severity": "high",
      "confidence": "medium",
      "provenance": {"source": "OpenRouter ecosystem documentation and examples", "url": "https://openrouter.ai/docs/api/api-reference/overview", "license": "vendor-documentation", "qualification": "prefix evidence found, official format-length evidence incomplete"}
    },
    {
      "rule_id": "CRT-PROV-002",
      "name": "RESEND_API_KEY_CANDIDATE",
      "regex": "re_[A-Za-z0-9_-]{20,200}(?![A-Za-z0-9_-])",
      "severity": "high",
      "confidence": "medium",
      "provenance": {"source": "Resend GitHub secret-scanning partner notice and ecosystem examples", "url": "https://resend.com/changelog/github-secret-scanner", "license": "vendor-documentation", "qualification": "prefix evidence found, official format-length evidence incomplete"}
    },
    {
